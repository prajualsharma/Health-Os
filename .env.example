# HealthOS Docker Compose — copy to .env and edit before deploy.
#   cp .env.example .env

# Required: 32+ character secret for JWT signing (generate with: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret

# Postgres
POSTGRES_DB=healthos
POSTGRES_USER=healthos
POSTGRES_PASSWORD=healthos

# API gateway (only published port in backend-only deploy)
API_GATEWAY_PORT=8080
CORS_ALLOWED_ORIGINS=*

# Phone OTP — set false to send real OTP emails via SMTP
OTP_DEV_BYPASS=false
DEV_OTP_CODE=123456

# JWT issuers (consumer vs staff pools; gateway accepts all three)
JWT_ISSUER=healthos
JWT_CONSUMER_ISSUER=healthos-consumer
JWT_STAFF_ISSUER=healthos-staff

# Notification tenantId = organization scopeId (not a global magic string)
NOTIFICATION_TENANT_ID=healthos

# Consumer identity scale triggers (split service when MAU exceeds threshold)
CONSUMER_SPLIT_MAU_THRESHOLD=500000
OTP_CONSUMER_RATE_LIMIT_PER_HOUR=10

# Email inbox that receives login OTP codes (phone login still uses your number)
OTP_EMAIL_TO=prajual.sharma.1559@gmail.com

# Gmail SMTP (create an App Password: Google Account → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=prajual.sharma.1559@gmail.com
SMTP_PASSWORD=cajt ckgw ssxv muko
SMTP_FROM=prajual.sharma.1559@gmail.com

# Optional: Google OAuth client id for gateway
GOOGLE_CLIENT_ID=

# Full-stack only (ignored by backend-only overlay)
WEB_PORT=80
FRONTEND_API_URL=
FRONTEND_USE_MOCK=false
